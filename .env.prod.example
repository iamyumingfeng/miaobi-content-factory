# ========================================
# 妙笔内容工场 - 生产环境配置模板
# ========================================
# 复制此文件为 .env.prod 并根据实际情况修改配置
# 
# ⚠️  安全提示：
# 1. 所有密码必须使用强密码（至少16位，包含大小写字母、数字、特殊字符）
# 2. SECRET_KEY 必须使用随机生成的密钥
# 3. 生产环境必须配置 HTTPS
# 4. 定期更换密码和密钥
# ========================================

# ========================================
# Docker Compose 项目名称
# ========================================
# 用于区分同一服务器上的多个系统部署
# 默认值：auto-aigc-factory
# 如果部署多个实例，请修改为不同的名称
COMPOSE_PROJECT_NAME=auto-aigc-factory

# ========================================
# 通用配置
# ========================================
# 运行模式: production（生产环境必须设置为 production）
ENVIRONMENT=production
DEBUG=false

# ========================================
# 数据库配置 - MySQL
# ========================================
# ⚠️  生产环境必须修改以下密码
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=aigc_platform
MYSQL_USER=aigc_user
# 生产环境数据库用户密码（建议使用密码管理器生成）
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# 生产环境数据库 root 密码（建议使用密码管理器生成）
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD_HERE

# ========================================
# 缓存配置 - Redis
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
# 生产环境 Redis 密码（建议使用密码管理器生成）
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_HERE
REDIS_DB=0

# ========================================
# 后端API配置
# ========================================
API_PORT=8000
# 生产环境必须使用 production target
API_TARGET=production
# ⚠️  必须使用随机生成的密钥（至少32位）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=2f1b1054c4d9ac3977211c17bbad57983516cd939ce6d7c1361abb7680e6f17b
JWT_ALGORITHM=HS256
# 访问令牌过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 刷新令牌过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置 (JSON数组格式)
# ⚠️  生产环境必须配置实际的域名
# 示例: ["https://yourdomain.com","https://www.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ========================================
# 前端Web配置
# ========================================
WEB_PORT=80
# 生产环境必须使用 production target
WEB_TARGET=production
WEB_INTERNAL_PORT=3000
# ⚠️  生产环境必须配置实际的 API 地址
# 示例: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ========================================
# Celery配置
# ========================================
# Celery 并发数（根据服务器 CPU 核心数调整）
CELERY_CONCURRENCY=4
TASK_QUEUE_MAX_CONCURRENT=8
FLOWER_PORT=5555

# ========================================
# 对象存储配置 - 腾讯云COS
# ========================================
# ⚠️  生产环境必须配置 COS 密钥
# COS 密钥（从腾讯云控制台获取）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
# COS 存储桶名称
COS_BUCKET=your-bucket-name
# COS 地域
# 常见地域：ap-beijing, ap-shanghai, ap-guangzhou, ap-chengdu 等
COS_REGION=
# COS 挂载路径（本地服务器上 COS 的挂载目录）
COS_MOUNT_PATH=/app/cos
# COS URL 前缀（可选，若不填则自动根据 bucket 和 region 生成）
# COS_URL_PREFIX=https://your-bucket-name.cos.ap-guangzhou.myqcloud.com
# COS 路径前缀（可选，如果COS上的文件不在根目录，需要配置）
# 例如：如果文件在 /auto_aigc_factory/ 下，配置为 /auto_aigc_factory
COS_PATH_PREFIX=/auto_aigc_factory

# ========================================
# 存储 URL 类型配置
# ========================================
# 文件访问 URL 类型：
# - auto: 自动检测（默认），有 COS 配置时返回 COS URL，否则返回 IP 路径
# - local: 强制返回本地路径 (/cos/...)
# - cos: 强制返回 COS 公网 URL（需要配置 COS）
# - ip: 强制返回服务器 IP + 路径格式 (http://your-ip/cos/...)
STORAGE_URL_TYPE=auto
STORAGE_URL_PREFIX=http://localhost:8000

# ========================================
# 图片处理配置
# ========================================
# 参考图传输方式：True=公网URL，False=Base64
# 生产环境推荐：true（使用 COS 公网 URL 减少数据传输）
IMAGE_PREFER_URL=false

# ========================================
# 初始管理员账号
# ========================================
# ⚠️  首次部署后立即修改默认密码
INITIAL_SUPER_ADMIN_USERID=admin_root
INITIAL_SUPER_ADMIN_PASSWORD=admin_root123
INITIAL_SUPER_ADMIN_NICKNAME=超级管理员

# ========================================
# 初始运营管理员账号
# ========================================
# ⚠️  首次部署后立即修改默认密码
INITIAL_OPERATOR_ADMIN_USERID=operator_default
INITIAL_OPERATOR_ADMIN_PASSWORD=operator_default123
INITIAL_OPERATOR_ADMIN_NICKNAME=默认运营管理员

# ========================================
# 备份配置
# ========================================
# 备份文件存放目录（默认为 data/backups）
BACKUP_DIR=data/backups

# ========================================
# 平台模型类型配置
# ========================================
# 配置各平台支持的模型类型（逗号分隔，可选值：llm, image, video）
PLATFORM_BAILIAN_TYPES=llm,image,embedding
PLATFORM_VOLCANO_TYPES=llm,image
PLATFORM_JIMENG_TYPES=image
PLATFORM_KLING_TYPES=image
PLATFORM_ZHIPU_TYPES=llm
PLATFORM_MOONSHOT_TYPES=llm
PLATFORM_DEEPSEEK_TYPES=llm
PLATFORM_LINGYAAI_TYPES=llm,image
PLATFORM_4SAPI_TYPES=llm,image

# ========================================
# AI 模型 API 配置(仅初始化使用）)
# ========================================
# ⚠️  根据实际使用的平台配置对应的 API Key
# 未配置的平台将无法使用

# 阿里百炼 API Key
BAILIAN_API_KEY=

# 火山引擎 API Key
VOLCANO_API_KEY=

# 即梦 AccessKey 和 SecretKey
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=

# 可灵 AccessKey 和 SecretKey
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# 智谱 API Key
ZHIPU_API_KEY=

# 月之暗面 API Key
MOONSHOT_API_KEY=

# DeepSeek API Key
DEEPSEEK_API_KEY=

# 灵芽API API Key
LINGYAAI_API_KEY=

# 4sAPI API Key
4SAPI_API_KEY=

# ========================================
# 部署配置
# ========================================
# 部署环境标识（用于日志和监控）
DEPLOY_ENV=production
# 服务器域名（用于生成访问链接）
SERVER_DOMAIN=localhost
# 是否启用 HTTPS（生产环境推荐启用）
ENABLE_HTTPS=false

